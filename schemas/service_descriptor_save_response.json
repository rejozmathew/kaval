{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "DescriptorSource": {
      "description": "Origins for service descriptors.",
      "enum": [
        "shipped",
        "auto_generated",
        "user"
      ],
      "title": "DescriptorSource",
      "type": "string"
    },
    "DescriptorViewContainerDependencyResponse": {
      "additionalProperties": false,
      "description": "One rendered container dependency entry.",
      "properties": {
        "alternatives": {
          "items": {
            "type": "string"
          },
          "title": "Alternatives",
          "type": "array"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "DescriptorViewContainerDependencyResponse",
      "type": "object"
    },
    "DescriptorViewCredentialHintResponse": {
      "additionalProperties": false,
      "description": "One rendered credential-hint entry.",
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        }
      },
      "required": [
        "key",
        "description",
        "location"
      ],
      "title": "DescriptorViewCredentialHintResponse",
      "type": "object"
    },
    "DescriptorViewEndpointResponse": {
      "additionalProperties": false,
      "description": "One rendered descriptor endpoint.",
      "properties": {
        "auth": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth"
        },
        "auth_header": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Header"
        },
        "healthy_when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Healthy When"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "port": {
          "title": "Port",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "port"
      ],
      "title": "DescriptorViewEndpointResponse",
      "type": "object"
    },
    "DescriptorViewFailureModeResponse": {
      "additionalProperties": false,
      "description": "One rendered failure-mode entry.",
      "properties": {
        "check_first": {
          "items": {
            "type": "string"
          },
          "title": "Check First",
          "type": "array"
        },
        "likely_cause": {
          "title": "Likely Cause",
          "type": "string"
        },
        "trigger": {
          "title": "Trigger",
          "type": "string"
        }
      },
      "required": [
        "trigger",
        "likely_cause"
      ],
      "title": "DescriptorViewFailureModeResponse",
      "type": "object"
    },
    "DescriptorViewInspectionSurfaceResponse": {
      "additionalProperties": false,
      "description": "One rendered inspection-surface entry.",
      "properties": {
        "auth": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth"
        },
        "auth_header": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Header"
        },
        "confidence_effect": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence Effect"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "facts_provided": {
          "items": {
            "type": "string"
          },
          "title": "Facts Provided",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "read_only": {
          "default": true,
          "title": "Read Only",
          "type": "boolean"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "version_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version Range"
        }
      },
      "required": [
        "id",
        "type",
        "description"
      ],
      "title": "DescriptorViewInspectionSurfaceResponse",
      "type": "object"
    },
    "DescriptorViewLogSignalsResponse": {
      "additionalProperties": false,
      "description": "Rendered log-signal section for one descriptor.",
      "properties": {
        "errors": {
          "items": {
            "type": "string"
          },
          "title": "Errors",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "title": "DescriptorViewLogSignalsResponse",
      "type": "object"
    },
    "DescriptorViewMatchResponse": {
      "additionalProperties": false,
      "description": "Rendered match rules for one descriptor view.",
      "properties": {
        "container_name_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Container Name Patterns",
          "type": "array"
        },
        "image_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Image Patterns",
          "type": "array"
        }
      },
      "title": "DescriptorViewMatchResponse",
      "type": "object"
    },
    "DnsRecordType": {
      "description": "Supported deterministic DNS record types for Phase 1.",
      "enum": [
        "A",
        "AAAA"
      ],
      "title": "DnsRecordType",
      "type": "string"
    },
    "DnsTarget": {
      "additionalProperties": false,
      "description": "A DNS record target that should resolve for a service.",
      "properties": {
        "expected_values": {
          "items": {
            "type": "string"
          },
          "title": "Expected Values",
          "type": "array"
        },
        "host": {
          "title": "Host",
          "type": "string"
        },
        "record_type": {
          "$ref": "#/$defs/DnsRecordType"
        }
      },
      "required": [
        "host",
        "record_type"
      ],
      "title": "DnsTarget",
      "type": "object"
    },
    "ServiceDescriptorViewResponse": {
      "additionalProperties": false,
      "description": "Rendered descriptor view contract for the admin UI.",
      "properties": {
        "category": {
          "title": "Category",
          "type": "string"
        },
        "common_failure_modes": {
          "items": {
            "$ref": "#/$defs/DescriptorViewFailureModeResponse"
          },
          "title": "Common Failure Modes",
          "type": "array"
        },
        "credential_hints": {
          "items": {
            "$ref": "#/$defs/DescriptorViewCredentialHintResponse"
          },
          "title": "Credential Hints",
          "type": "array"
        },
        "descriptor_id": {
          "title": "Descriptor Id",
          "type": "string"
        },
        "dns_targets": {
          "items": {
            "$ref": "#/$defs/DnsTarget"
          },
          "title": "Dns Targets",
          "type": "array"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/DescriptorViewEndpointResponse"
          },
          "title": "Endpoints",
          "type": "array"
        },
        "file_path": {
          "title": "File Path",
          "type": "string"
        },
        "generated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated At"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "inspection_surfaces": {
          "items": {
            "$ref": "#/$defs/DescriptorViewInspectionSurfaceResponse"
          },
          "title": "Inspection Surfaces",
          "type": "array"
        },
        "investigation_context": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Investigation Context"
        },
        "log_signals": {
          "$ref": "#/$defs/DescriptorViewLogSignalsResponse"
        },
        "match": {
          "$ref": "#/$defs/DescriptorViewMatchResponse"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "project_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Project Url"
        },
        "raw_yaml": {
          "title": "Raw Yaml",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/DescriptorSource"
        },
        "typical_dependency_containers": {
          "items": {
            "$ref": "#/$defs/DescriptorViewContainerDependencyResponse"
          },
          "title": "Typical Dependency Containers",
          "type": "array"
        },
        "typical_dependency_shares": {
          "items": {
            "type": "string"
          },
          "title": "Typical Dependency Shares",
          "type": "array"
        },
        "verified": {
          "default": true,
          "title": "Verified",
          "type": "boolean"
        },
        "write_target_path": {
          "title": "Write Target Path",
          "type": "string"
        }
      },
      "required": [
        "descriptor_id",
        "file_path",
        "write_target_path",
        "name",
        "category",
        "source",
        "match",
        "raw_yaml"
      ],
      "title": "ServiceDescriptorViewResponse",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Mutation response for one descriptor editor save action.",
  "properties": {
    "audit_change": {
      "$ref": "#/$defs/Change"
    },
    "descriptor": {
      "$ref": "#/$defs/ServiceDescriptorViewResponse"
    }
  },
  "required": [
    "descriptor",
    "audit_change"
  ],
  "title": "ServiceDescriptorSaveResponse",
  "type": "object"
}
