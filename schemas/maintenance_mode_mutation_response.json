{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "MaintenanceModeResponse": {
      "additionalProperties": false,
      "description": "Current active global and per-service maintenance windows.",
      "properties": {
        "global_window": {
          "anyOf": [
            {
              "$ref": "#/$defs/MaintenanceWindowResponse"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "self_health_guardrail": {
          "title": "Self Health Guardrail",
          "type": "string"
        },
        "service_windows": {
          "items": {
            "$ref": "#/$defs/MaintenanceWindowResponse"
          },
          "title": "Service Windows",
          "type": "array"
        }
      },
      "required": [
        "self_health_guardrail"
      ],
      "title": "MaintenanceModeResponse",
      "type": "object"
    },
    "MaintenanceScope": {
      "description": "Supported maintenance window scopes.",
      "enum": [
        "global",
        "service"
      ],
      "title": "MaintenanceScope",
      "type": "string"
    },
    "MaintenanceWindowResponse": {
      "additionalProperties": false,
      "description": "One active maintenance window visible to the operator.",
      "properties": {
        "expires_at": {
          "format": "date-time",
          "title": "Expires At",
          "type": "string"
        },
        "minutes_remaining": {
          "minimum": 0,
          "title": "Minutes Remaining",
          "type": "integer"
        },
        "scope": {
          "$ref": "#/$defs/MaintenanceScope"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service Id"
        },
        "service_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service Name"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "started_at",
        "expires_at",
        "minutes_remaining"
      ],
      "title": "MaintenanceWindowResponse",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Mutation result for one maintenance mode create or clear action.",
  "properties": {
    "audit_change": {
      "$ref": "#/$defs/Change"
    },
    "maintenance": {
      "$ref": "#/$defs/MaintenanceModeResponse"
    }
  },
  "required": [
    "maintenance",
    "audit_change"
  ],
  "title": "MaintenanceModeMutationResponse",
  "type": "object"
}
