{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "ModelSettingsCloudScopeResponse": {
      "additionalProperties": false,
      "description": "One staged or active cloud-model settings view.",
      "properties": {
        "api_key_configured": {
          "title": "Api Key Configured",
          "type": "boolean"
        },
        "api_key_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Key Ref"
        },
        "api_key_source": {
          "$ref": "#/$defs/ModelSettingsSecretSource"
        },
        "base_url": {
          "title": "Base Url",
          "type": "string"
        },
        "configured": {
          "title": "Configured",
          "type": "boolean"
        },
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "max_output_tokens": {
          "minimum": 1,
          "title": "Max Output Tokens",
          "type": "integer"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "provider": {
          "enum": [
            "anthropic",
            "openai",
            "openai_compatible"
          ],
          "title": "Provider",
          "type": "string"
        },
        "timeout_seconds": {
          "exclusiveMinimum": 0,
          "title": "Timeout Seconds",
          "type": "number"
        }
      },
      "required": [
        "enabled",
        "provider",
        "base_url",
        "timeout_seconds",
        "max_output_tokens",
        "api_key_source",
        "api_key_configured",
        "configured"
      ],
      "title": "ModelSettingsCloudScopeResponse",
      "type": "object"
    },
    "ModelSettingsEscalationResponse": {
      "additionalProperties": false,
      "description": "Staged or active escalation thresholds and bounded cost controls.",
      "properties": {
        "escalate_on_changelog_research": {
          "title": "Escalate On Changelog Research",
          "type": "boolean"
        },
        "escalate_on_multiple_domains": {
          "title": "Escalate On Multiple Domains",
          "type": "boolean"
        },
        "escalate_on_user_request": {
          "title": "Escalate On User Request",
          "type": "boolean"
        },
        "finding_count_gt": {
          "minimum": 0,
          "title": "Finding Count Gt",
          "type": "integer"
        },
        "local_confidence_lt": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Local Confidence Lt",
          "type": "number"
        },
        "max_cloud_calls_per_day": {
          "minimum": 1,
          "title": "Max Cloud Calls Per Day",
          "type": "integer"
        },
        "max_cloud_calls_per_incident": {
          "minimum": 1,
          "title": "Max Cloud Calls Per Incident",
          "type": "integer"
        }
      },
      "required": [
        "finding_count_gt",
        "local_confidence_lt",
        "escalate_on_multiple_domains",
        "escalate_on_changelog_research",
        "escalate_on_user_request",
        "max_cloud_calls_per_day",
        "max_cloud_calls_per_incident"
      ],
      "title": "ModelSettingsEscalationResponse",
      "type": "object"
    },
    "ModelSettingsLocalScopeResponse": {
      "additionalProperties": false,
      "description": "One staged or active local-model settings view.",
      "properties": {
        "api_key_configured": {
          "title": "Api Key Configured",
          "type": "boolean"
        },
        "api_key_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Key Ref"
        },
        "api_key_source": {
          "$ref": "#/$defs/ModelSettingsSecretSource"
        },
        "base_url": {
          "title": "Base Url",
          "type": "string"
        },
        "configured": {
          "title": "Configured",
          "type": "boolean"
        },
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "provider": {
          "const": "openai_compatible",
          "title": "Provider",
          "type": "string"
        },
        "timeout_seconds": {
          "exclusiveMinimum": 0,
          "title": "Timeout Seconds",
          "type": "number"
        }
      },
      "required": [
        "enabled",
        "provider",
        "base_url",
        "timeout_seconds",
        "api_key_source",
        "api_key_configured",
        "configured"
      ],
      "title": "ModelSettingsLocalScopeResponse",
      "type": "object"
    },
    "ModelSettingsResponse": {
      "additionalProperties": false,
      "description": "Model-settings payload with explicit staged and active snapshots.",
      "properties": {
        "active": {
          "$ref": "#/$defs/ModelSettingsScopeResponse"
        },
        "apply_required": {
          "title": "Apply Required",
          "type": "boolean"
        },
        "config_path": {
          "title": "Config Path",
          "type": "string"
        },
        "last_applied_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Last Applied At"
        },
        "load_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Load Error"
        },
        "staged": {
          "$ref": "#/$defs/ModelSettingsScopeResponse"
        }
      },
      "required": [
        "config_path",
        "apply_required",
        "last_applied_at",
        "active",
        "staged"
      ],
      "title": "ModelSettingsResponse",
      "type": "object"
    },
    "ModelSettingsScopeResponse": {
      "additionalProperties": false,
      "description": "One complete staged or active model-settings snapshot.",
      "properties": {
        "cloud": {
          "$ref": "#/$defs/ModelSettingsCloudScopeResponse"
        },
        "escalation": {
          "$ref": "#/$defs/ModelSettingsEscalationResponse"
        },
        "local": {
          "$ref": "#/$defs/ModelSettingsLocalScopeResponse"
        }
      },
      "required": [
        "local",
        "cloud",
        "escalation"
      ],
      "title": "ModelSettingsScopeResponse",
      "type": "object"
    },
    "ModelSettingsSecretSource": {
      "description": "How one model API key is currently sourced.",
      "enum": [
        "vault",
        "env",
        "unset"
      ],
      "title": "ModelSettingsSecretSource",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Mutation response for staged-save or explicit-apply model settings actions.",
  "properties": {
    "audit_change": {
      "$ref": "#/$defs/Change"
    },
    "settings": {
      "$ref": "#/$defs/ModelSettingsResponse"
    }
  },
  "required": [
    "settings",
    "audit_change"
  ],
  "title": "ModelSettingsMutationResponse",
  "type": "object"
}
