{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "Evidence": {
      "additionalProperties": false,
      "description": "A single piece of evidence attached to a finding.",
      "properties": {
        "data": {
          "anyOf": [
            {
              "$ref": "#/$defs/JsonValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "source",
        "summary",
        "observed_at"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "EvidenceKind": {
      "description": "Supported evidence categories.",
      "enum": [
        "log",
        "probe",
        "config",
        "api",
        "event",
        "memory",
        "metric"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "Finding": {
      "additionalProperties": false,
      "description": "An atomic monitoring observation.",
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "domain": {
          "title": "Domain",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "title": "Evidence",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "impact": {
          "title": "Impact",
          "type": "string"
        },
        "incident_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Incident Id"
        },
        "related_changes": {
          "items": {
            "$ref": "#/$defs/Change"
          },
          "title": "Related Changes",
          "type": "array"
        },
        "resolved_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Resolved At"
        },
        "service_id": {
          "title": "Service Id",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "status": {
          "$ref": "#/$defs/FindingStatus"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "severity",
        "domain",
        "service_id",
        "summary",
        "evidence",
        "impact",
        "confidence",
        "status",
        "incident_id",
        "related_changes",
        "created_at",
        "resolved_at"
      ],
      "title": "Finding",
      "type": "object"
    },
    "FindingFeedbackReason": {
      "description": "Explicit operator reasons for dismissing one finding as noise.",
      "enum": [
        "false_positive",
        "expected_behavior",
        "not_important",
        "already_aware"
      ],
      "title": "FindingFeedbackReason",
      "type": "string"
    },
    "FindingFeedbackSuggestionAction": {
      "description": "Operator-controlled next steps suggested from repeated dismissals.",
      "enum": [
        "suppress_check",
        "adjust_threshold_or_suppress"
      ],
      "title": "FindingFeedbackSuggestionAction",
      "type": "string"
    },
    "FindingFeedbackSuggestionResponse": {
      "additionalProperties": false,
      "description": "One advisory recommendation derived from repeated finding dismissals.",
      "properties": {
        "action": {
          "$ref": "#/$defs/FindingFeedbackSuggestionAction"
        },
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "check_label": {
          "title": "Check Label",
          "type": "string"
        },
        "dismissal_count": {
          "minimum": 1,
          "title": "Dismissal Count",
          "type": "integer"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "service_id": {
          "title": "Service Id",
          "type": "string"
        },
        "service_name": {
          "title": "Service Name",
          "type": "string"
        }
      },
      "required": [
        "service_id",
        "service_name",
        "check_id",
        "check_label",
        "dismissal_count",
        "action",
        "message"
      ],
      "title": "FindingFeedbackSuggestionResponse",
      "type": "object"
    },
    "FindingReviewItemResponse": {
      "additionalProperties": false,
      "description": "One active or recently dismissed finding shown in the review panel.",
      "properties": {
        "dismissal_count_for_pattern": {
          "default": 0,
          "minimum": 0,
          "title": "Dismissal Count For Pattern",
          "type": "integer"
        },
        "dismissal_reason": {
          "anyOf": [
            {
              "$ref": "#/$defs/FindingFeedbackReason"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "domain_label": {
          "title": "Domain Label",
          "type": "string"
        },
        "finding": {
          "$ref": "#/$defs/Finding"
        },
        "service_name": {
          "title": "Service Name",
          "type": "string"
        },
        "suggestion": {
          "anyOf": [
            {
              "$ref": "#/$defs/FindingFeedbackSuggestionResponse"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "finding",
        "service_name",
        "domain_label"
      ],
      "title": "FindingReviewItemResponse",
      "type": "object"
    },
    "FindingReviewResponse": {
      "additionalProperties": false,
      "description": "Finding review payload with active, dismissed, and recommended noise controls.",
      "properties": {
        "active_findings": {
          "items": {
            "$ref": "#/$defs/FindingReviewItemResponse"
          },
          "title": "Active Findings",
          "type": "array"
        },
        "recently_dismissed": {
          "items": {
            "$ref": "#/$defs/FindingReviewItemResponse"
          },
          "title": "Recently Dismissed",
          "type": "array"
        },
        "suggestions": {
          "items": {
            "$ref": "#/$defs/FindingFeedbackSuggestionResponse"
          },
          "title": "Suggestions",
          "type": "array"
        }
      },
      "title": "FindingReviewResponse",
      "type": "object"
    },
    "FindingStatus": {
      "description": "Lifecycle states for findings.",
      "enum": [
        "new",
        "grouped",
        "investigating",
        "resolved",
        "dismissed",
        "stale"
      ],
      "title": "FindingStatus",
      "type": "string"
    },
    "JsonValue": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "Severity": {
      "description": "Supported severity values.",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Dismissal result for one finding plus refreshed review state.",
  "properties": {
    "audit_change": {
      "$ref": "#/$defs/Change"
    },
    "finding": {
      "$ref": "#/$defs/Finding"
    },
    "review": {
      "$ref": "#/$defs/FindingReviewResponse"
    }
  },
  "required": [
    "finding",
    "review",
    "audit_change"
  ],
  "title": "FindingDismissResponse",
  "type": "object"
}
