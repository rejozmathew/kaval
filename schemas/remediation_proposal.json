{
  "$defs": {
    "ActionType": {
      "description": "Executor action types frozen in Phase 0.",
      "enum": [
        "restart_container",
        "pull_specific_image_tag",
        "start_vm",
        "stop_vm",
        "modify_config_with_backup"
      ],
      "title": "ActionType",
      "type": "string"
    },
    "RemediationStatus": {
      "description": "Lifecycle states for remediation proposals.",
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "executed",
        "verified"
      ],
      "title": "RemediationStatus",
      "type": "string"
    },
    "RiskAssessment": {
      "additionalProperties": false,
      "description": "Structured risk output for a remediation proposal.",
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/RiskCheck"
          },
          "title": "Checks",
          "type": "array"
        },
        "overall_risk": {
          "$ref": "#/$defs/RiskLevel"
        },
        "reversible": {
          "title": "Reversible",
          "type": "boolean"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "overall_risk",
        "checks",
        "reversible",
        "warnings"
      ],
      "title": "RiskAssessment",
      "type": "object"
    },
    "RiskCheck": {
      "additionalProperties": false,
      "description": "An individual remediation risk check.",
      "properties": {
        "check": {
          "title": "Check",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "result": {
          "$ref": "#/$defs/RiskCheckResult"
        }
      },
      "required": [
        "check",
        "result",
        "detail"
      ],
      "title": "RiskCheck",
      "type": "object"
    },
    "RiskCheckResult": {
      "description": "Outcomes for individual risk checks.",
      "enum": [
        "pass",
        "fail",
        "unknown"
      ],
      "title": "RiskCheckResult",
      "type": "string"
    },
    "RiskLevel": {
      "description": "Risk levels for remediation proposals.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "A proposed system-changing action and its risk assessment.",
  "properties": {
    "action_type": {
      "$ref": "#/$defs/ActionType"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "risk_assessment": {
      "$ref": "#/$defs/RiskAssessment"
    },
    "status": {
      "$ref": "#/$defs/RemediationStatus"
    },
    "target": {
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "action_type",
    "target",
    "rationale",
    "risk_assessment",
    "status"
  ],
  "title": "RemediationProposal",
  "type": "object"
}
