{
  "$defs": {
    "CredentialVaultCredentialResponse": {
      "additionalProperties": false,
      "description": "One stored credential summary with no secret material.",
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "credential_description": {
          "title": "Credential Description",
          "type": "string"
        },
        "credential_key": {
          "title": "Credential Key",
          "type": "string"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "last_tested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Tested At"
        },
        "last_used_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Used At"
        },
        "reference_id": {
          "title": "Reference Id",
          "type": "string"
        },
        "service_id": {
          "title": "Service Id",
          "type": "string"
        },
        "service_name": {
          "title": "Service Name",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/CredentialVaultEntrySource"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "reference_id",
        "source",
        "service_id",
        "service_name",
        "credential_key",
        "credential_description",
        "created_at",
        "updated_at"
      ],
      "title": "CredentialVaultCredentialResponse",
      "type": "object"
    },
    "CredentialVaultEntrySource": {
      "description": "Source types for stored vault credentials shown in the admin UI.",
      "enum": [
        "credential_request",
        "managed_setting"
      ],
      "title": "CredentialVaultEntrySource",
      "type": "string"
    },
    "VaultStatus": {
      "additionalProperties": false,
      "description": "Runtime lock state for the credential vault.",
      "properties": {
        "initialized": {
          "title": "Initialized",
          "type": "boolean"
        },
        "stored_credentials": {
          "title": "Stored Credentials",
          "type": "integer"
        },
        "unlock_expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Unlock Expires At"
        },
        "unlocked": {
          "title": "Unlocked",
          "type": "boolean"
        }
      },
      "required": [
        "initialized",
        "unlocked",
        "unlock_expires_at",
        "stored_credentials"
      ],
      "title": "VaultStatus",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Full operator-facing vault state and stored-credential list.",
  "properties": {
    "auto_lock_minutes": {
      "minimum": 1,
      "title": "Auto Lock Minutes",
      "type": "integer"
    },
    "credentials": {
      "items": {
        "$ref": "#/$defs/CredentialVaultCredentialResponse"
      },
      "title": "Credentials",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/VaultStatus"
    }
  },
  "required": [
    "status",
    "auto_lock_minutes"
  ],
  "title": "CredentialVaultResponse",
  "type": "object"
}
