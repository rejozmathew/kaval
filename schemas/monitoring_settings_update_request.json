{
  "$defs": {
    "MonitoringSettingsCheckUpdateRequest": {
      "additionalProperties": false,
      "description": "Writable global monitoring-check settings payload.",
      "properties": {
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "interval_seconds": {
          "minimum": 1,
          "title": "Interval Seconds",
          "type": "integer"
        },
        "probe_timeout_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Probe Timeout Seconds"
        },
        "restart_delta_threshold": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Restart Delta Threshold"
        },
        "tls_warning_days": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tls Warning Days"
        }
      },
      "required": [
        "check_id",
        "enabled",
        "interval_seconds"
      ],
      "title": "MonitoringSettingsCheckUpdateRequest",
      "type": "object"
    },
    "MonitoringSettingsServiceOverrideUpdateRequest": {
