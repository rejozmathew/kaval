{
  "$defs": {
    "DependencyConfidence": {
      "description": "Confidence levels for dependency edges.",
      "enum": [
        "configured",
        "runtime_observed",
        "user_confirmed",
        "inferred",
        "auto_generated"
      ],
      "title": "DependencyConfidence",
      "type": "string"
    },
    "DependencyEdge": {
      "additionalProperties": false,
      "description": "A directed dependency from one service to another.",
      "properties": {
        "confidence": {
          "$ref": "#/$defs/DependencyConfidence"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description"
        },
        "source": {
          "$ref": "#/$defs/DependencySource"
        },
        "target_service_id": {
          "title": "Target Service Id",
          "type": "string"
        }
      },
      "required": [
        "target_service_id",
        "confidence",
        "source",
        "description"
      ],
      "title": "DependencyEdge",
      "type": "object"
    },
    "DependencySource": {
      "description": "Sources used to infer a dependency edge.",
      "enum": [
        "docker_network",
        "shared_volume",
        "descriptor",
        "user",
        "llm"
      ],
      "title": "DependencySource",
      "type": "string"
    },
    "DescriptorSource": {
      "description": "Origins for service descriptors.",
      "enum": [
        "shipped",
        "auto_generated",
        "user"
      ],
      "title": "DescriptorSource",
      "type": "string"
    },
    "DescriptorViewContainerDependencyResponse": {
      "additionalProperties": false,
      "description": "One rendered container dependency entry.",
      "properties": {
        "alternatives": {
          "items": {
            "type": "string"
          },
          "title": "Alternatives",
          "type": "array"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "DescriptorViewContainerDependencyResponse",
      "type": "object"
    },
    "DescriptorViewCredentialHintResponse": {
      "additionalProperties": false,
      "description": "One rendered credential-hint entry.",
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        }
      },
      "required": [
        "key",
        "description",
        "location"
      ],
      "title": "DescriptorViewCredentialHintResponse",
      "type": "object"
    },
    "DescriptorViewEndpointResponse": {
      "additionalProperties": false,
      "description": "One rendered descriptor endpoint.",
      "properties": {
        "auth": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth"
        },
        "auth_header": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Header"
        },
        "healthy_when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Healthy When"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "port": {
          "title": "Port",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "port"
      ],
      "title": "DescriptorViewEndpointResponse",
      "type": "object"
    },
    "DescriptorViewFailureModeResponse": {
      "additionalProperties": false,
      "description": "One rendered failure-mode entry.",
      "properties": {
        "check_first": {
          "items": {
            "type": "string"
          },
          "title": "Check First",
          "type": "array"
        },
        "likely_cause": {
          "title": "Likely Cause",
          "type": "string"
        },
        "trigger": {
          "title": "Trigger",
          "type": "string"
        }
      },
      "required": [
        "trigger",
        "likely_cause"
      ],
      "title": "DescriptorViewFailureModeResponse",
      "type": "object"
    },
    "DescriptorViewInspectionSurfaceResponse": {
      "additionalProperties": false,
      "description": "One rendered inspection-surface entry.",
      "properties": {
        "auth": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth"
        },
        "auth_header": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Header"
        },
        "confidence_effect": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence Effect"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "facts_provided": {
          "items": {
            "type": "string"
          },
          "title": "Facts Provided",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "read_only": {
          "default": true,
          "title": "Read Only",
          "type": "boolean"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "version_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version Range"
        }
      },
      "required": [
        "id",
        "type",
        "description"
      ],
      "title": "DescriptorViewInspectionSurfaceResponse",
      "type": "object"
    },
    "DescriptorViewLogSignalsResponse": {
      "additionalProperties": false,
      "description": "Rendered log-signal section for one descriptor.",
      "properties": {
        "errors": {
          "items": {
            "type": "string"
          },
          "title": "Errors",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "title": "DescriptorViewLogSignalsResponse",
      "type": "object"
    },
    "DescriptorViewMatchResponse": {
      "additionalProperties": false,
      "description": "Rendered match rules for one descriptor view.",
      "properties": {
        "container_name_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Container Name Patterns",
          "type": "array"
        },
        "image_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Image Patterns",
          "type": "array"
        }
      },
      "title": "DescriptorViewMatchResponse",
      "type": "object"
    },
    "DnsRecordType": {
      "description": "Supported deterministic DNS record types for Phase 1.",
      "enum": [
        "A",
        "AAAA"
      ],
      "title": "DnsRecordType",
      "type": "string"
    },
    "DnsTarget": {
      "additionalProperties": false,
      "description": "A DNS record target that should resolve for a service.",
      "properties": {
        "expected_values": {
          "items": {
            "type": "string"
          },
          "title": "Expected Values",
          "type": "array"
        },
        "host": {
          "title": "Host",
          "type": "string"
        },
        "record_type": {
          "$ref": "#/$defs/DnsRecordType"
        }
      },
      "required": [
        "host",
        "record_type"
      ],
      "title": "DnsTarget",
      "type": "object"
    },
    "Endpoint": {
      "additionalProperties": false,
      "description": "A network or application endpoint exposed by a service.",
      "properties": {
        "auth_required": {
          "default": false,
          "title": "Auth Required",
          "type": "boolean"
        },
        "expected_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Expected Status"
        },
        "host": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Host"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Port"
        },
        "protocol": {
          "$ref": "#/$defs/EndpointProtocol"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "required": [
        "name",
        "protocol",
        "port",
        "expected_status"
      ],
      "title": "Endpoint",
      "type": "object"
    },
    "EndpointProtocol": {
      "description": "Supported endpoint protocols.",
      "enum": [
        "http",
        "https",
        "tcp"
      ],
      "title": "EndpointProtocol",
      "type": "string"
    },
    "Service": {
      "additionalProperties": false,
      "description": "A discovered service in the monitored environment.",
      "properties": {
        "active_findings": {
          "minimum": 0,
          "title": "Active Findings",
          "type": "integer"
        },
        "active_incidents": {
          "minimum": 0,
          "title": "Active Incidents",
          "type": "integer"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "container_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Container Id"
        },
        "dependencies": {
          "items": {
            "$ref": "#/$defs/DependencyEdge"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "dependents": {
          "items": {
            "type": "string"
          },
          "title": "Dependents",
          "type": "array"
        },
        "descriptor_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Descriptor Id"
        },
        "descriptor_source": {
          "anyOf": [
            {
              "$ref": "#/$defs/DescriptorSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "dns_targets": {
          "items": {
            "$ref": "#/$defs/DnsTarget"
          },
          "title": "Dns Targets",
          "type": "array"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/Endpoint"
          },
          "title": "Endpoints",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Image"
        },
        "insight": {
          "anyOf": [
            {
              "$ref": "#/$defs/ServiceInsight"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "last_check": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Last Check"
        },
        "lifecycle": {
          "$ref": "#/$defs/ServiceLifecycle"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ServiceStatus"
        },
        "type": {
          "$ref": "#/$defs/ServiceType"
        },
        "vm_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Vm Id"
        }
      },
      "required": [
        "id",
        "name",
        "type",
        "category",
        "status",
        "descriptor_id",
        "descriptor_source",
        "container_id",
        "vm_id",
        "image",
        "endpoints",
        "dependencies",
        "dependents",
        "last_check",
        "active_findings",
        "active_incidents"
      ],
      "title": "Service",
      "type": "object"
    },
    "ServiceDescriptorViewResponse": {
      "additionalProperties": false,
      "description": "Rendered descriptor view contract for the admin UI.",
      "properties": {
        "category": {
          "title": "Category",
          "type": "string"
        },
        "common_failure_modes": {
          "items": {
            "$ref": "#/$defs/DescriptorViewFailureModeResponse"
          },
          "title": "Common Failure Modes",
          "type": "array"
        },
        "credential_hints": {
          "items": {
            "$ref": "#/$defs/DescriptorViewCredentialHintResponse"
          },
          "title": "Credential Hints",
          "type": "array"
        },
        "descriptor_id": {
          "title": "Descriptor Id",
          "type": "string"
        },
        "dns_targets": {
          "items": {
            "$ref": "#/$defs/DnsTarget"
          },
          "title": "Dns Targets",
          "type": "array"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/DescriptorViewEndpointResponse"
          },
          "title": "Endpoints",
          "type": "array"
        },
        "file_path": {
          "title": "File Path",
          "type": "string"
        },
        "generated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated At"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "inspection_surfaces": {
          "items": {
            "$ref": "#/$defs/DescriptorViewInspectionSurfaceResponse"
          },
          "title": "Inspection Surfaces",
          "type": "array"
        },
        "investigation_context": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Investigation Context"
        },
        "log_signals": {
          "$ref": "#/$defs/DescriptorViewLogSignalsResponse"
        },
        "match": {
          "$ref": "#/$defs/DescriptorViewMatchResponse"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "project_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Project Url"
        },
        "raw_yaml": {
          "title": "Raw Yaml",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/DescriptorSource"
        },
        "typical_dependency_containers": {
          "items": {
            "$ref": "#/$defs/DescriptorViewContainerDependencyResponse"
          },
          "title": "Typical Dependency Containers",
          "type": "array"
        },
        "typical_dependency_shares": {
          "items": {
            "type": "string"
          },
          "title": "Typical Dependency Shares",
          "type": "array"
        },
        "verified": {
          "default": true,
          "title": "Verified",
          "type": "boolean"
        },
        "write_target_path": {
          "title": "Write Target Path",
          "type": "string"
        }
      },
      "required": [
        "descriptor_id",
        "file_path",
        "write_target_path",
        "name",
        "category",
        "source",
        "match",
        "raw_yaml"
      ],
      "title": "ServiceDescriptorViewResponse",
      "type": "object"
    },
    "ServiceInsight": {
      "additionalProperties": false,
      "description": "The current insight depth available for one service.",
      "properties": {
        "level": {
          "$ref": "#/$defs/ServiceInsightLevel"
        }
      },
      "required": [
        "level"
      ],
      "title": "ServiceInsight",
      "type": "object"
    },
    "ServiceInsightLevel": {
      "description": "Supported per-service insight levels.",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "title": "ServiceInsightLevel",
      "type": "integer"
    },
    "ServiceLifecycle": {
      "additionalProperties": false,
      "description": "Lifecycle metadata retained for one service across discovery cycles.",
      "properties": {
        "changed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Changed At"
        },
        "last_event": {
          "anyOf": [
            {
              "$ref": "#/$defs/ServiceLifecycleEventType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "previous_descriptor_ids": {
          "items": {
            "type": "string"
          },
          "title": "Previous Descriptor Ids",
          "type": "array"
        },
        "previous_names": {
          "items": {
            "type": "string"
          },
          "title": "Previous Names",
          "type": "array"
        },
        "state": {
          "$ref": "#/$defs/ServiceLifecycleState",
          "default": "active"
        }
      },
      "title": "ServiceLifecycle",
      "type": "object"
    },
    "ServiceLifecycleEventType": {
      "description": "Lifecycle events derived from discovery and trusted context.",
      "enum": [
        "service_added",
        "service_updated",
        "service_restarted",
        "service_removed_intentional",
        "service_removed_unexpectedly",
        "service_removed_during_maintenance",
        "service_renamed_or_rematched"
      ],
      "title": "ServiceLifecycleEventType",
      "type": "string"
    },
    "ServiceLifecycleState": {
      "description": "Persistent lifecycle states for a discovered service.",
      "enum": [
        "active",
        "missing",
        "removed_intentional",
        "removed_during_maintenance"
      ],
      "title": "ServiceLifecycleState",
      "type": "string"
    },
    "ServiceStatus": {
      "description": "Supported service health states.",
      "enum": [
        "healthy",
        "degraded",
        "down",
        "unknown",
        "stopped"
      ],
      "title": "ServiceStatus",
      "type": "string"
    },
    "ServiceType": {
      "description": "Supported service types.",
      "enum": [
        "container",
        "vm",
        "plugin",
        "share",
        "system",
        "external",
        "network"
      ],
      "title": "ServiceType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "One quarantined descriptor candidate shown in the review queue.",
  "properties": {
    "descriptor": {
      "$ref": "#/$defs/ServiceDescriptorViewResponse"
    },
    "matching_services": {
      "items": {
        "$ref": "#/$defs/Service"
      },
      "title": "Matching Services",
      "type": "array"
    },
    "review_state": {
      "title": "Review State",
      "type": "string"
    },
    "review_updated_at": {
      "format": "date-time",
      "title": "Review Updated At",
      "type": "string"
    }
  },
  "required": [
    "descriptor",
    "review_state",
    "review_updated_at"
  ],
  "title": "QuarantinedDescriptorQueueItemResponse",
  "type": "object"
}
