{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "CredentialVaultCredentialResponse": {
      "additionalProperties": false,
      "description": "One stored credential summary with no secret material.",
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "credential_description": {
          "title": "Credential Description",
          "type": "string"
        },
        "credential_key": {
          "title": "Credential Key",
          "type": "string"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "last_tested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Tested At"
        },
        "last_used_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Used At"
        },
        "reference_id": {
          "title": "Reference Id",
          "type": "string"
        },
        "service_id": {
          "title": "Service Id",
          "type": "string"
        },
        "service_name": {
          "title": "Service Name",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/CredentialVaultEntrySource"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "reference_id",
        "source",
        "service_id",
        "service_name",
        "credential_key",
        "credential_description",
        "created_at",
        "updated_at"
      ],
      "title": "CredentialVaultCredentialResponse",
      "type": "object"
    },
    "CredentialVaultEntrySource": {
      "description": "Source types for stored vault credentials shown in the admin UI.",
      "enum": [
        "credential_request",
        "managed_setting"
      ],
      "title": "CredentialVaultEntrySource",
      "type": "string"
    },
    "CredentialVaultResponse": {
      "additionalProperties": false,
      "description": "Full operator-facing vault state and stored-credential list.",
      "properties": {
        "auto_lock_minutes": {
          "minimum": 1,
          "title": "Auto Lock Minutes",
          "type": "integer"
        },
        "credentials": {
          "items": {
            "$ref": "#/$defs/CredentialVaultCredentialResponse"
          },
          "title": "Credentials",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/VaultStatus"
        }
      },
      "required": [
        "status",
        "auto_lock_minutes"
      ],
      "title": "CredentialVaultResponse",
      "type": "object"
    },
    "CredentialVaultTestItemResponse": {
      "additionalProperties": false,
      "description": "Result for one explicit vault readability test item.",
      "properties": {
        "checked_at": {
          "format": "date-time",
          "title": "Checked At",
          "type": "string"
        },
        "credential_description": {
          "title": "Credential Description",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "ok": {
          "title": "Ok",
          "type": "boolean"
        },
        "reference_id": {
          "title": "Reference Id",
          "type": "string"
        },
        "service_name": {
          "title": "Service Name",
          "type": "string"
        }
      },
      "required": [
        "reference_id",
        "service_name",
        "credential_description",
        "ok",
        "message",
        "checked_at"
      ],
      "title": "CredentialVaultTestItemResponse",
      "type": "object"
    },
    "VaultStatus": {
      "additionalProperties": false,
      "description": "Runtime lock state for the credential vault.",
      "properties": {
        "initialized": {
          "title": "Initialized",
          "type": "boolean"
        },
        "stored_credentials": {
          "title": "Stored Credentials",
          "type": "integer"
        },
        "unlock_expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Unlock Expires At"
        },
        "unlocked": {
          "title": "Unlocked",
          "type": "boolean"
        }
      },
      "required": [
        "initialized",
        "unlocked",
        "unlock_expires_at",
        "stored_credentials"
      ],
      "title": "VaultStatus",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Result for one explicit test of all stored vault credentials.",
  "properties": {
    "audit_change": {
      "anyOf": [
        {
          "$ref": "#/$defs/Change"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "ok": {
      "title": "Ok",
      "type": "boolean"
    },
    "readable_credentials": {
      "minimum": 0,
      "title": "Readable Credentials",
      "type": "integer"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/CredentialVaultTestItemResponse"
      },
      "title": "Results",
      "type": "array"
    },
    "tested_credentials": {
      "minimum": 0,
      "title": "Tested Credentials",
      "type": "integer"
    },
    "vault": {
      "$ref": "#/$defs/CredentialVaultResponse"
    }
  },
  "required": [
    "vault",
    "ok",
    "checked_at",
    "tested_credentials",
    "readable_credentials",
    "message"
  ],
  "title": "CredentialVaultTestResponse",
  "type": "object"
}
