{
  "$defs": {
    "Change": {
      "additionalProperties": false,
      "description": "A timeline event that may correlate with findings or incidents.",
      "properties": {
        "correlated_incidents": {
          "items": {
            "type": "string"
          },
          "title": "Correlated Incidents",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "new_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "New Value"
        },
        "old_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Old Value"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Service Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ChangeType"
        }
      },
      "required": [
        "id",
        "type",
        "service_id",
        "description",
        "old_value",
        "new_value",
        "timestamp",
        "correlated_incidents"
      ],
      "title": "Change",
      "type": "object"
    },
    "ChangeType": {
      "description": "Supported change event types.",
      "enum": [
        "service_added",
        "service_removed",
        "service_missing",
        "service_renamed_or_rematched",
        "image_update",
        "container_restart",
        "config_change",
        "unraid_event",
        "plugin_update",
        "external_change"
      ],
      "title": "ChangeType",
      "type": "string"
    },
    "NotificationSettingsChannelScopeResponse": {
      "additionalProperties": false,
      "description": "One staged or active notification channel view.",
      "properties": {
        "destination_configured": {
          "title": "Destination Configured",
          "type": "boolean"
        },
        "destination_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Destination Ref"
        },
        "destination_source": {
          "$ref": "#/$defs/NotificationSettingsSecretSource"
        },
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "kind",
        "enabled",
        "destination_source",
        "destination_configured"
      ],
      "title": "NotificationSettingsChannelScopeResponse",
      "type": "object"
    },
    "NotificationSettingsQuietHoursResponse": {
      "additionalProperties": false,
      "description": "Staged or active quiet-hours schedule metadata.",
      "properties": {
        "active_now": {
          "title": "Active Now",
          "type": "boolean"
        },
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "end_time_local": {
          "title": "End Time Local",
          "type": "string"
        },
        "quiet_until": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quiet Until"
        },
        "start_time_local": {
          "title": "Start Time Local",
          "type": "string"
        },
        "timezone": {
          "title": "Timezone",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "start_time_local",
        "end_time_local",
        "timezone",
        "active_now"
      ],
      "title": "NotificationSettingsQuietHoursResponse",
      "type": "object"
    },
    "NotificationSettingsResponse": {
      "additionalProperties": false,
      "description": "Notification-settings payload with explicit staged and active snapshots.",
      "properties": {
        "active": {
          "$ref": "#/$defs/NotificationSettingsScopeResponse"
        },
        "apply_required": {
          "title": "Apply Required",
          "type": "boolean"
        },
        "config_path": {
          "title": "Config Path",
          "type": "string"
        },
        "last_applied_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Last Applied At"
        },
        "load_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Load Error"
        },
        "staged": {
          "$ref": "#/$defs/NotificationSettingsScopeResponse"
        }
      },
      "required": [
        "config_path",
        "apply_required",
        "last_applied_at",
        "active",
        "staged"
      ],
      "title": "NotificationSettingsResponse",
      "type": "object"
    },
    "NotificationSettingsRoutingResponse": {
      "additionalProperties": false,
      "description": "Staged or active severity routing and dedup policy.",
      "properties": {
        "critical": {
          "enum": [
            "immediate",
            "immediate_with_dedup",
            "hourly_digest",
            "dashboard_only"
          ],
          "title": "Critical",
          "type": "string"
        },
        "dedup_window_minutes": {
          "minimum": 1,
          "title": "Dedup Window Minutes",
          "type": "integer"
        },
        "digest_window_minutes": {
          "minimum": 1,
          "title": "Digest Window Minutes",
          "type": "integer"
        },
        "high": {
          "enum": [
            "immediate",
            "immediate_with_dedup",
            "hourly_digest",
            "dashboard_only"
          ],
          "title": "High",
          "type": "string"
        },
        "low": {
          "enum": [
            "immediate",
            "immediate_with_dedup",
            "hourly_digest",
            "dashboard_only"
          ],
          "title": "Low",
          "type": "string"
        },
        "medium": {
          "enum": [
            "immediate",
            "immediate_with_dedup",
            "hourly_digest",
            "dashboard_only"
          ],
          "title": "Medium",
          "type": "string"
        }
      },
      "required": [
        "critical",
        "high",
        "medium",
        "low",
        "dedup_window_minutes",
        "digest_window_minutes"
      ],
      "title": "NotificationSettingsRoutingResponse",
      "type": "object"
    },
    "NotificationSettingsScopeResponse": {
      "additionalProperties": false,
      "description": "One complete staged or active notification-settings snapshot.",
      "properties": {
        "channels": {
          "items": {
            "$ref": "#/$defs/NotificationSettingsChannelScopeResponse"
          },
          "title": "Channels",
          "type": "array"
        },
        "configured_channel_count": {
          "minimum": 0,
          "title": "Configured Channel Count",
          "type": "integer"
        },
        "quiet_hours": {
          "$ref": "#/$defs/NotificationSettingsQuietHoursResponse"
        },
        "routing": {
          "$ref": "#/$defs/NotificationSettingsRoutingResponse"
        }
      },
      "required": [
        "routing",
        "quiet_hours",
        "configured_channel_count"
      ],
      "title": "NotificationSettingsScopeResponse",
      "type": "object"
    },
    "NotificationSettingsSecretSource": {
      "description": "How one notification destination is currently sourced.",
      "enum": [
        "vault",
        "env",
        "unset"
      ],
      "title": "NotificationSettingsSecretSource",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Mutation response for staged-save or explicit-apply notification settings actions.",
  "properties": {
    "audit_change": {
      "$ref": "#/$defs/Change"
    },
    "settings": {
      "$ref": "#/$defs/NotificationSettingsResponse"
    }
  },
  "required": [
    "settings",
    "audit_change"
  ],
  "title": "NotificationSettingsMutationResponse",
  "type": "object"
}
