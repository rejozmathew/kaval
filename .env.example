# Compose and image settings
KAVAL_IMAGE="ghcr.io/rejozmathew/kaval:private-testing"
KAVAL_CONTAINER_NAME="kaval"
KAVAL_HTTP_PORT="9800"
KAVAL_DATA_DIR="./.data/kaval"
TZ="UTC"

# Required runtime secret
KAVAL_APPROVAL_HMAC_SECRET="replace-with-a-long-random-secret"

# Optional widget bootstrap
KAVAL_WIDGET_ENABLED="true"
KAVAL_WIDGET_API_KEY=""
KAVAL_WIDGET_PUBLIC_URL=""
KAVAL_WIDGET_REFRESH_INTERVAL_SECONDS="60"

# Optional local model bootstrap
KAVAL_LOCAL_MODEL_NAME=""
KAVAL_LOCAL_MODEL_BASE_URL="http://localhost:11434"
KAVAL_LOCAL_MODEL_TIMEOUT_SECONDS="30"
KAVAL_LOCAL_MODEL_API_KEY=""

# Optional cloud model bootstrap
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
KAVAL_CLOUD_MODEL_NAME=""
KAVAL_CLOUD_MODEL_PROVIDER="anthropic"
KAVAL_CLOUD_MODEL_BASE_URL=""
KAVAL_CLOUD_MODEL_API_KEY_ENV="ANTHROPIC_API_KEY"
KAVAL_CLOUD_MODEL_TIMEOUT_SECONDS="45"
KAVAL_CLOUD_MODEL_MAX_OUTPUT_TOKENS="1600"
KAVAL_CLOUD_MODEL_MAX_CALLS_PER_INCIDENT="3"
KAVAL_CLOUD_MODEL_MAX_CALLS_PER_DAY="20"
KAVAL_CLOUD_ESCALATION_LOCAL_CONFIDENCE_LT="0.6"
KAVAL_CLOUD_ESCALATION_FINDING_COUNT_GT="3"

# Optional notification bootstrap
KAVAL_NOTIFICATION_ENABLED="true"
KAVAL_NOTIFICATION_URLS=""
KAVAL_TELEGRAM_BOT_TOKEN=""
KAVAL_TELEGRAM_CHAT_ID=""
KAVAL_TELEGRAM_API_BASE_URL="https://api.telegram.org"
KAVAL_TELEGRAM_TIMEOUT_SECONDS="15"
KAVAL_TELEGRAM_WEBHOOK_SECRET=""

# Optional webhook bootstrap
KAVAL_WEBHOOK_KEY_UPTIME_KUMA=""
KAVAL_WEBHOOK_KEY_GRAFANA=""
KAVAL_WEBHOOK_KEY_PROMETHEUS_ALERTMANAGER=""
KAVAL_WEBHOOK_KEY_NETDATA=""
KAVAL_WEBHOOK_KEY_GENERIC_JSON=""

# Runtime tuning
KAVAL_VAULT_AUTO_LOCK_MINUTES="5"
KAVAL_VOLATILE_CREDENTIAL_TTL_SECONDS="1800"
KAVAL_CORE_LOG_LEVEL="info"
