# Project-scoped Codex MCP example for TaskMaster
# Copy to .codex/config.toml and replace env values as needed.

[mcp_servers.taskmaster_ai]
command = "npx"
args = ["-y", "task-master-ai"]
startup_timeout_sec = 20
tool_timeout_sec = 120
enabled = true
required = false

[mcp_servers.taskmaster_ai.env]
OPENAI_API_KEY = "REPLACE_WITH_TASKMASTER_MODEL_KEY"
# Or swap to another supported provider key if you prefer.
